# Normalise all text files to LF on checkout
* text=auto eol=lf

# Explicitly declare common .NET file types as text
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf

# Binary files — never touch line endings
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.exe       binary
*.dll       binary
